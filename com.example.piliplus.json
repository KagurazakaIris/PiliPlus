{
    "app-id": "com.example.piliplus",
    "runtime": "org.freedesktop.Platform",
    "runtime-version": "24.08",
    "sdk": "org.freedesktop.Sdk",
    "command": "piliplus",
    "finish-args": [
        "--share=network",
        "--share=ipc",
        "--socket=fallback-x11",
        "--socket=wayland",
        "--device=dri",
        "--filesystem=home:ro"
    ],
    "modules": [
        {
            "name": "piliplus",
            "buildsystem": "simple",
            "build-commands": [
                "install -D piliplus /app/bin/piliplus",
                "cp -r lib /app/",
                "cp -r data /app/",
                "install -Dm644 linux/com.example.piliplus.desktop /app/share/applications/com.example.piliplus.desktop",
                "install -Dm644 images/logo/logo.png /app/share/icons/hicolor/512x512/apps/piliplus.png"
            ],
            "sources": [
                {
                    "type": "dir",
                    "path": "build/linux/x64/release/bundle"
                },
                {
                    "type": "dir",
                    "path": "assets"
                }
            ]
        }
    ]
}